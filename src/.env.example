APP_NAME="RAG_Project"
APP_VERSION="0.1"
API_BASE_URL="http://127.0.0.1:8000"

MODEL_NAME="command-r-plus-08-2024"

COHERE_API_KEY=""

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=RAG_Project
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

FILE_ALLOWED_TYPES=["text/plain","application/pdf"]
FILE_MAX_SIZE=20
HF_HUB_OFFLINE=0
FILE_DEFAULT_CHUNK_SIZE= 512000

FLASH_MODEL_RERANKER ="ms-marco-TinyBERT-L-2-v2"
fLASH_CACHE_DIR="/tmp/flashrank_cache"

TAVILY_API_KEY=""
chunk_size=512
chunk_overlap=200
EMBEDDING_MODEL_NAME="BAAI/bge-small-en-v1.5"
TOP_K_RERANKER=2
TOP_K_BM25=2
TOP_K_HYBRID=3
SPLADEE_MODEL_NAME="prithvida/Splade_PP_en_v1"

REDIS_HOST = redis
REDIS_PORT = 6379
TELEGRAM_BOT_TOKEN=""


QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_documents
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
QDRANT_DENSE_DIM=384
QDRANT_UPSERT_BATCH_SIZE=4
QDRANT_POINTS_UPSERT_BATCH_SIZE=64
QDRANT_SCROLL_LIMIT_OVERLAP=1000
QDRANT_SCROLL_LIMIT_SYNC=500
METADATA_DB_NAME=file_metadata.db

EVAL_MAX_QUESTIONS=3
EVAL_RETRIEVAL_K=3
EVAL_MAX_CONTEXT_CHARS=300
EVAL_MAX_RESPONSE_CHARS=600
EVAL_SLEEP_BETWEEN_SAMPLES=2
EVAL_LLM_MODEL=llama-3.1-8b-instant
EVAL_LLM_TEMPERATURE=0.0
EVAL_LLM_MAX_TOKENS=1024
EVAL_RELEVANCY_STRICTNESS=1
EVAL_MAX_WORKERS=1
EVAL_TIMEOUT=300
EVAL_MAX_RETRIES=20
EVAL_MAX_WAIT=5

DENSE_SEARCH_WEIGHT=0.4
SPARSE_SEARCH_WEIGHT=0.6

TOP_K_TAVILY=3
DUPLICATE_THRESHOLD=0.35
